{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "baseUrl": "src",
    "outDir": "../.tmp",
    "sourceMap": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "strictNullChecks": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": false,
    "resolveJsonModule": true,
    "useDefineForClassFields": false
  },
  "exclude": [
    "./dist",
    "./node_modules"
    //"**/*.spec.ts"
  ],
  "files": [
    "./src/polyfills.ts"
  ],
  "awesomeTypescriptLoaderOptions": {
    "silent": true
  }
}
